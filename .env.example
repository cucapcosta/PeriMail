# ─── Discord ──────────────────────────────────────────────────────────────────
# Bot token from discord.com/developers → your app → Bot → Token
DISCORD_BOT_TOKEN=

# Your personal Discord user ID (right-click your name → Copy User ID, needs Developer Mode on)
DISCORD_USER_ID=

# ─── Google Gemini ────────────────────────────────────────────────────────────
# API key from aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─── Gmail OAuth ──────────────────────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# App type: Web application. Add redirect URI: https://<your-app>.up.railway.app/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Encryption ───────────────────────────────────────────────────────────────
# 32 random bytes, base64-encoded. Generate once and keep secret:
# python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=

# ─── App URL ──────────────────────────────────────────────────────────────────
# Public URL of your Railway bot service (no trailing slash), used for OAuth callback
# e.g. https://perimail-bot-production.up.railway.app
PUBLIC_URL=

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string — Railway sets this automatically when you add a PostgreSQL service
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=

# ─── Optional ─────────────────────────────────────────────────────────────────
# Port for the OAuth callback HTTP server (Railway sets this automatically)
PORT=8080
